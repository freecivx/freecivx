<div id="nations_dialog">
  <div id="nations_header">
    <div id="nations_title"></div>
    <div id="nations_label"></div>
  </div>
  <div id="nations_button_div">
    <button id="view_player_button" type="button" class="button nations_action_btn" title=""><i class="fa fa-map-marker" aria-hidden="true"></i> View on Map</button>
    <button id="meet_player_button" type="button" class="button nations_action_btn" title=""><i class="fa fa-handshake-o" aria-hidden="true"></i> Meet Player</button>
    <button id="cancel_treaty_button" type="button" class="button nations_action_btn" title=""><i class="fa fa-ban" aria-hidden="true"></i> Cancel Treaty</button>
    <button id="withdraw_vision_button" type="button" class="button nations_action_btn" title=""><i class="fa fa-eye-slash" aria-hidden="true"></i> Withdraw Vision</button>
    <button id="take_player_button" type="button" class="button nations_action_btn" title=""><i class="fa fa-user" aria-hidden="true"></i> Play as this nation</button>
    <button id="toggle_ai_button" type="button" class="button nations_action_btn" title=""><i class="fa fa-android" aria-hidden="true"></i> Toggle AI mode</button>
    <button id="intelligence_report_button" type="button" class="button nations_action_btn" title=""><i class="fa fa-search" aria-hidden="true"></i> Intelligence report</button>
    <button id="send_message_button" type="button" class="button nations_action_btn" title=""><i class="fa fa-envelope" aria-hidden="true"></i> Send message</button>
  </div>

  <div id="nations">
    <div id="nations_list">
    </div>
  </div>
</div>
